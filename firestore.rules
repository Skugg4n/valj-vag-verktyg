rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public, no-login story copies for the /spela/:id reader. Anyone may
    // open a story they have the link to (get), but nobody can enumerate them
    // all (list is denied). Only the signed-in owner may create/update/delete.
    match /published/{shareId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }
  }
}